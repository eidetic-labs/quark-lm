{
  "project": "quark-lm",
  "version": "0.1.0",
  "purity_boundary": {
    "pretrained_weights": false,
    "pretrained_tokenizer": false,
    "external_embeddings": false,
    "outside_web_or_model_synthesis": false,
    "training_data_policy": "Only generated curriculum derived from allowed source files in this ledger may be used for training."
